</div>

{% raw %}
<script>
document.getElementById('hmg-menu-btn').addEventListener('click', function() {
  this.classList.toggle('open');
  document.getElementById('hmg-dropdown').classList.toggle('open');
});
document.addEventListener('click', function(e) {
  var wrap = document.querySelector('.hmg-hamburger-wrap');
  if (wrap && !wrap.contains(e.target)) {
    document.getElementById('hmg-menu-btn').classList.remove('open');
    document.getElementById('hmg-dropdown').classList.remove('open');
  }
});
</script>
{% endraw %}
</body>
