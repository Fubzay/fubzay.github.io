{% raw %}<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{--green:#2e7d4f;--green-light:#d0edd9;--green-bg:#f4fbf7;--text:#111;--muted:#444;--border:#ddd;}
html,body{background:#fff;font-family:'DM Sans',sans-serif;color:var(--text);}
body{max-width:960px;margin:0 auto;}

/* NAV */
.hmg-nav{display:flex;align-items:center;justify-content:space-between;padding:1.1rem 2rem;border-bottom:1px solid var(--border);background:#fff;position:sticky;top:0;z-index:50;}
.hmg-logo{font-family:'DM Serif Display',serif;font-size:18px;color:#111;text-decoration:none;}
.hmg-logo span{color:var(--green);}
.hmg-nav-links{display:flex;gap:1.8rem;list-style:none;}
.hmg-nav-links a{font-size:12px;font-weight:500;text-decoration:none;color:#111;letter-spacing:.5px;text-transform:uppercase;transition:color .15s;}
.hmg-nav-links a:hover{color:var(--green);}
.hmg-nav-right{display:flex;align-items:center;gap:10px;}
.hmg-nav-cta{font-size:13px;font-weight:500;padding:8px 20px;border-radius:100px;background:var(--green);color:#fff;text-decoration:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;}

/* HAMBURGER DROPDOWN */
.hmg-hamburger-wrap{position:relative;}
.hmg-hamburger-btn{display:flex;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none;flex-shrink:0;}
.hmg-hamburger-btn span{display:block;width:22px;height:2px;background:#111;border-radius:2px;transition:all .25s;}
.hmg-hamburger-btn.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hmg-hamburger-btn.open span:nth-child(2){opacity:0;}
.hmg-hamburger-btn.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.hmg-dropdown{display:none;position:absolute;top:calc(100% + 10px);right:0;background:#fff;border:2px solid #ddd;border-radius:12px;min-width:220px;box-shadow:0 8px 30px rgba(0,0,0,.12);overflow:hidden;z-index:200;}
.hmg-dropdown.open{display:block;}
.hmg-dropdown a{display:flex;align-items:center;gap:10px;padding:13px 18px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;color:#111;text-decoration:none;border-bottom:1px solid #f0f0f0;transition:background .15s;}
.hmg-dropdown a:last-child{border-bottom:none;}
.hmg-dropdown a:hover{background:#f4fbf7;color:var(--green);}
.hmg-dropdown-icon{width:18px;height:18px;flex-shrink:0;}
.hmg-dropdown-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#aaa;padding:10px 18px 6px;display:block;}

/* BACK BAR */
.back-bar{padding:.85rem 2.5rem;border-bottom:1px solid var(--border);background:#fafafa;}
.back-link{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--muted);text-decoration:none;transition:color .15s;}
.back-link:hover{color:var(--green);}

/* HERO */
.booking-hero{background:var(--green);padding:3.5rem 2.5rem;color:#fff;}
.booking-hero p{font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:.75rem;}
.booking-hero h1{font-family:'DM Serif Display',serif;font-size:42px;letter-spacing:-.5px;margin-bottom:.75rem;}
.booking-hero span{font-size:15px;color:rgba(255,255,255,.85);line-height:1.6;display:block;}

/* INFO STRIP */
.info-strip{display:grid;grid-template-columns:repeat(3,1fr);border-bottom:1px solid var(--border);}
.info-strip-item{padding:1.5rem 2rem;border-right:1px solid var(--border);}
.info-strip-item:last-child{border-right:none;}
.info-strip-item .label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--green);margin-bottom:.4rem;}
.info-strip-item .value{font-size:14px;font-weight:600;color:#111;margin-bottom:.2rem;}
.info-strip-item .sub{font-size:12px;color:var(--muted);line-height:1.5;}

/* PACKAGES */
.packages-section{padding:2.5rem 2.5rem;border-bottom:1px solid var(--border);background:#fafafa;}
.packages-section h2{font-family:'DM Serif Display',serif;font-size:26px;margin-bottom:.4rem;}
.packages-section>p{font-size:13px;color:var(--muted);margin-bottom:1.5rem;}
.packages-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.pkg-card{background:#fff;border:2px solid var(--border);border-radius:12px;padding:1.4rem;}
.pkg-card.featured{border-color:var(--green);background:var(--green-bg);}
.pkg-name{font-family:'DM Serif Display',serif;font-size:18px;margin-bottom:.3rem;}
.pkg-subtitle{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--green);margin-bottom:.75rem;}
.pkg-price{font-size:32px;font-weight:300;color:var(--green);letter-spacing:-1px;margin-bottom:.75rem;}
.pkg-price span{font-size:13px;color:#888;font-weight:400;}
.pkg-features{list-style:none;display:flex;flex-direction:column;gap:6px;}
.pkg-features li{font-size:12.5px;color:var(--muted);display:flex;align-items:center;gap:7px;}
.pkg-features li::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--green);flex-shrink:0;}

/* RULES */
.rules-section{padding:2rem 2.5rem;border-bottom:1px solid var(--border);background:#fff;}
.rules-section h2{font-family:'DM Serif Display',serif;font-size:20px;margin-bottom:1rem;}
.rules-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.rule-item{display:flex;align-items:flex-start;gap:10px;padding:12px 14px;background:#fafafa;border:1px solid var(--border);border-radius:9px;}
.rule-icon{width:32px;height:32px;border-radius:8px;background:var(--green-bg);border:1px solid var(--green-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.rule-text{font-size:12.5px;color:var(--muted);line-height:1.5;}
.rule-text strong{color:#111;display:block;margin-bottom:1px;font-size:13px;}

/* CALENDLY */
.calendly-section{padding:2.5rem 2.5rem;border-bottom:1px solid var(--border);}
.calendly-section h2{font-family:'DM Serif Display',serif;font-size:26px;margin-bottom:.4rem;}
.calendly-section>p{font-size:13px;color:var(--muted);margin-bottom:1.5rem;}
.calendly-wrap{border:2px solid var(--border);border-radius:14px;overflow:hidden;}

/* CALL SECTION */
.call-section{padding:2.5rem 2.5rem;border-bottom:1px solid var(--border);background:var(--green-bg);}
.call-inner{display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:center;}
.call-inner h2{font-family:'DM Serif Display',serif;font-size:26px;margin-bottom:.5rem;}
.call-inner p{font-size:14px;color:var(--muted);line-height:1.6;}
.call-btn{display:inline-flex;align-items:center;gap:8px;padding:13px 26px;border-radius:100px;background:var(--green);color:#fff;text-decoration:none;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;white-space:nowrap;}
.call-btn:hover{opacity:.88;}

/* FOOTER */
.hmg-footer{padding:2.25rem 2.5rem;display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:2rem;border-top:2px solid var(--border);}
.footer-brand{font-family:'DM Serif Display',serif;font-size:18px;margin-bottom:.65rem;color:#111;}
.footer-brand span{color:var(--green);}
.footer-desc{font-size:12.5px;color:#555;line-height:1.7;}
.footer-head{font-size:10px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:#111;margin-bottom:.85rem;}
.footer-links{display:flex;flex-direction:column;gap:7px;list-style:none;}
.footer-links a{font-size:13px;color:#555;text-decoration:none;}
.footer-links a:hover{color:var(--green);}
.footer-links li{font-size:12px;color:#555;}
.footer-bottom{border-top:1px solid var(--border);padding:.9rem 2.5rem;display:flex;justify-content:space-between;align-items:center;}
.footer-copy{font-size:11.5px;color:#777;}
.footer-social{display:flex;gap:12px;}
.footer-social a{font-size:11.5px;font-weight:600;color:#777;text-decoration:none;}
.footer-social a:hover{color:var(--green);}

/* MOBILE */
@media(max-width:700px){
  body{max-width:100%;}
  .hmg-nav{padding:.9rem 1.25rem;}
  .hmg-nav-links{display:none;}
  .hmg-nav-cta{display:none;}
  .back-bar{padding:.85rem 1.5rem;}
  .booking-hero{padding:2.5rem 1.5rem;}
  .booking-hero h1{font-size:32px;}
  .info-strip{grid-template-columns:1fr;}
  .info-strip-item{border-right:none;border-bottom:1px solid var(--border);}
  .info-strip-item:last-child{border-bottom:none;}
  .packages-section{padding:2rem 1.5rem;}
  .packages-grid{grid-template-columns:1fr;}
  .rules-section{padding:2rem 1.5rem;}
  .rules-grid{grid-template-columns:1fr;}
  .calendly-section{padding:2rem 1.5rem;}
  .call-section{padding:2rem 1.5rem;}
  .call-inner{grid-template-columns:1fr;gap:1rem;}
  .hmg-footer{grid-template-columns:1fr;padding:2rem 1.5rem;}
  .footer-bottom{flex-direction:column;gap:.75rem;text-align:center;padding:1rem 1.5rem;}
}
</style>{% endraw %}
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
